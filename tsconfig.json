{
"compilerOptions": {
"module": "CommonJS",
"target": "ES2020",
"outDir": "./dist",
"rootDir": "./src",
"strict": false,
"esModuleInterop": true,
"emitDecoratorMetadata": true,
"experimentalDecorators": true,
"skipLibCheck": true,
"forceConsistentCasingInFileNames": true
},
"include": ["src/**/*"],
"exclude": ["node_modules", "dist"]
}