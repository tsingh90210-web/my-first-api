<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Secure Payment</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="bg-light">
<div class="container mt-5">
<h2 class="text-center mb-4">Secure Payment</h2>
<div class="card shadow mx-auto" style="max-width: 450px;">
<div class="card-body p-4">
<form id="payForm">
<div class="mb-3">
<label class="form-label">Your Full Name</label>
<input type="text" id="userName" name="userName" class="form-control" required>
</div>
<div class="mb-4">
<label class="form-label">Amount (£)</label>
<input type="number" id="amount" name="amount" step="0.01" min="0.50" class="form-control" required>
</div>
<button type="submit" class="btn btn-primary w-100 py-2">Proceed to PayPal</button>
</form>
</div>
<div class="text-center mt-3">
<a href="/pay/dashboard">View Payment Dashboard</a>
</div>
</div>
</div>

<!-- ✅ THIS IS THE WORKING JAVASCRIPT WE NEED -->
<script>
const form = document.getElementById('payForm');

form.addEventListener('submit', async (e) => {
e.preventDefault();

const userName = document.getElementById('userName').value;
const amount = document.getElementById('amount').value;

try {
const res = await fetch('/pay/create', {
method: 'POST',
headers: { 'Content-Type': 'application/json' },
body: JSON.stringify({ userName, amount })
});

const result = await res.json();

if (result.approvalUrl) {
// ✅ Sends you straight to PayPal!
window.location.href = result.approvalUrl;
} else {
alert(result.error || 'Something went wrong');
}

} catch (err) {
alert('Something went wrong');
}
});
</script>
</body>
</html>
